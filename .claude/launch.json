{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "RapFlow Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "RapFlow Dev Server (port 3333)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "3333"],
      "port": 3333
    },
    {
      "name": "RapFlow Production Preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000
    }
  ]
}
